
<h2>Finology Products</h2>

<table>
  <tr>
	<th>Finology_Id</th>  
    <th>Name</th>
    <th>Price</th>
	<th>Details</th>
	<th>Extra-Information</th>	
  </tr>

  <% @products.each do |product|%>
  <tr>
    <td><%= product.product_id%></td>
    <td><%= product.name%></td>
    <td><%= product.price%></td>
	<td class="details-width"><%= simple_format product.details.strip.gsub('•','<br />•').html_safe%></td>	
	<td><%= product.extra_information.strip.gsub("\n",'').gsub("Material",'<br />Material : ').gsub("Pattern",'<br />Pattern : ').gsub("Climate",'<br />Climate : ').html_safe%></td>
	
  </tr>
  <%end%>
</table>